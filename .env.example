# Copy to .env.local for development, and set these as environment variables
# on your host for production.

# Signing key for the session JWT. REQUIRED in production — the server refuses
# to start signing sessions without it. Generate one with:
#   node -e "console.log(require('node:crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=

# Directory for the SQLite database file (lqk.db). In production, point this at
# a mounted persistent volume so data survives restarts/redeploys.
# Local dev can leave this unset (defaults to ./data).
LQK_DATA_DIR=/data

# Google Sheet backend for the Quran tracker (student roster + lessons), via its
# Apps Script web app. Defaults to the existing values if unset, but set these
# in production and rotate the token in the Apps Script (it has been public).
LQK_SHEET_URL=
LQK_SHEET_TOKEN=
